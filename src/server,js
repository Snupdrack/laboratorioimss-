const express = require("express");
const axios   = require("axios");
const path    = require("path");
const fs      = require("fs");

const { normalizeNubariumPremium } = require("./normalizers/nubariumPremium");
const { buildImssViewModel }       = require("./formatters/imssViewModel");
const { renderImssPdf }            = require("./renderers/imssPdfRenderer");

const app  = express();
const PORT = process.env.PORT || 3000;

// ── Config ───────────────────────────────────────────────────────────────────
const NUBARIUM_API_KEY = process.env.NUBARIUM_API_KEY || "TU_API_KEY_AQUI";
const MY_PUBLIC_URL    = process.env.MY_PUBLIC_URL || "https://tu-servidor.com";

const OUTPUT_DIR = path.join(__dirname, "../output");
const PUBLIC_DIR = path.join(__dirname, "../public");

if (!fs.existsSync(OUTPUT_DIR)) fs.mkdirSync(OUTPUT_DIR, { recursive: true });

// ── Middleware ───────────────────────────────────────────────────────────────
app.use(express.json());
app.use(express.static(PUBLIC_DIR));

// ── "Base de datos" temporal en memoria ─────────────────────────────────────
// Luego esto lo pasas a JSON o DB real
let consultas = [
  {
    id: 1,
    nombre: "FLORES GARZA AMARO",
    curp: "FOGA741213HDFMML00",
    nss: "98923404899",
    fecha: "24/03/2026",
    estado: "ok",
    archivo: "imss_historial_laboral.pdf",
    owner: "cliente",
    requestId: null
  }
];

function fechaHoyMX() {
  return new Date().toLocaleDateString("es-MX");
}

function authFromToken(req) {
  const authHeader = req.headers.authorization || "";
  const token = authHeader.replace("Bearer ", "").trim();

  if (token === "admin-token-demo") {
    return { username: "admin", role: "admin" };
  }

  if (token === "cliente-token-demo") {
    return { username: "cliente", role: "cliente" };
  }

  return null;
}

function requireAuth(req, res, next) {
  const user = authFromToken(req);
  if (!user) {
    return res.status(401).json({ error: "No autorizado" });
  }
  req.user = user;
  next();
}

function requireAdmin(req, res, next) {
  const user = authFromToken(req);
  if (!user || user.role !== "admin") {
    return res.status(403).json({ error: "Acceso solo para administradores" });
  }
  req.user = user;
  next();
}

// ── Frontend ─────────────────────────────────────────────────────────────────
app.get("/", (req, res) => {
  res.sendFile(path.join(PUBLIC_DIR, "login.html"));
});

// ── Login demo por roles ─────────────────────────────────────────────────────
app.post("/login", (req, res) => {
