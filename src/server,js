});

// ─────────────────────────────────────────────────────────────────────────────
// POST /generar-historial
// Body: { "curp": "...", "nombre": "..." }
// ─────────────────────────────────────────────────────────────────────────────
app.post("/generar-historial", requireAuth, async (req, res) => {
  const { curp, nombre } = req.body;

  if (!curp) {
    return res.status(400).json({ error: "El campo 'curp' es obligatorio" });
  }

  if (String(curp).trim().length !== 18) {
    return res.status(400).json({ error: "La CURP debe tener 18 caracteres" });
  }

  const curpUpper = String(curp).trim().toUpperCase();

  // Creamos registro local en pending antes de mandar a Nubarium
  const consultaLocal = {
    id: Date.now(),
    nombre: (nombre || "SIN NOMBRE").toUpperCase(),
    curp: curpUpper,
    nss: "—",
    fecha: fechaHoyMX(),
    estado: "pending",
    archivo: null,
    owner: req.user.username,
    requestId: null
  };

  consultas.unshift(consultaLocal);

  try {
    const nubariumRes = await axios.post(
      "https://api.nubarium.com/mex/plus/v2/imss-job-history",
      {
        curp: curpUpper,
        url: `${MY_PUBLIC_URL}/webhook/nubarium`,
        encabezados: {
          curp: curpUpper,
          owner: req.user.username,
          localId: consultaLocal.id
        }
      },
      {
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${NUBARIUM_API_KEY}`
        }
      }
    );

    // Si Nubarium devuelve algún identificador, lo guardamos
    if (nubariumRes?.data?.id) {
      consultaLocal.requestId = nubariumRes.data.id;
    }

    return res.json({
      ok: true,
      message: "Solicitud enviada a Nubarium. El PDF se generará cuando llegue la respuesta."
    });

  } catch (error) {
    consultaLocal.estado = "error";

    console.error("❌ Error al llamar a Nubarium:", error.message);

    return res.status(500).json({
      error: "Error al conectar con Nubarium"
    });
  }
});

// ─────────────────────────────────────────────────────────────────────────────
// POST /webhook/nubarium
// Nubarium llama aquí con el JSON del historial laboral
// ─────────────────────────────────────────────────────────────────────────────
app.post("/webhook/nubarium", async (req, res) => {
  const rawPayload = req.body;

  // responder rápido
  res.status(200).json({ ok: true });

  try {
    if (rawPayload.status !== "OK") {
      console.error("⚠️ Nubarium devolvió error:", rawPayload.message);

      // Intentamos marcar error si encontramos la consulta
      const curpFromHeader = rawPayload?.encabezados?.curp || rawPayload?.curp;
      const ownerFromHeader = rawPayload?.encabezados?.owner;

      const consultaError = consultas.find(c =>
        c.curp === curpFromHeader &&
        (!ownerFromHeader || c.owner === ownerFromHeader) &&
        c.estado === "pending"
      );

      if (consultaError) {
        consultaError.estado = "error";
      }

      return;
    }

    const normalized = normalizeNubariumPremium(rawPayload);
    const viewModel  = buildImssViewModel(normalized);

    const fileName   = `imss_${viewModel.nss || "historial"}_${Date.now()}.pdf`;
    const outputPath = path.join(OUTPUT_DIR, fileName);

    renderImssPdf(viewModel, outputPath);

    console.log(`✅ PDF generado: ${fileName}`);
    console.log(`👤 Nombre: ${viewModel.fullName}`);
    console.log(`📦 Empleos: ${viewModel.jobs.length}`);

    // Intentamos encontrar la consulta local para actualizarla
    const curpFromHeader  = rawPayload?.encabezados?.curp || viewModel?.curp || rawPayload?.curp;
    const ownerFromHeader = rawPayload?.encabezados?.owner;
    const localIdFromHeader = Number(rawPayload?.encabezados?.localId);

    let consulta = null;

    if (localIdFromHeader) {
      consulta = consultas.find(c => c.id === localIdFromHeader);
    }

    if (!consulta && curpFromHeader) {
      consulta = consultas.find(c =>
        c.curp === curpFromHeader &&
        (!ownerFromHeader || c.owner === ownerFromHeader) &&
        c.estado === "pending"
      );
    }

    if (consulta) {
      consulta.estado = "ok";
      consulta.archivo = fileName;
      consulta.nss = viewModel.nss || "—";
      consulta.nombre = viewModel.fullName || consulta.nombre;
    } else {
      // fallback: si no existe la consulta, la registramos para no perder trazabilidad
      consultas.unshift({
        id: Date.now(),
        nombre: viewModel.fullName || "SIN NOMBRE",
        curp: curpFromHeader || "—",
        nss: viewModel.nss || "—",
        fecha: fechaHoyMX(),
        estado: "ok",
        archivo: fileName,
        owner: ownerFromHeader || "cliente",
        requestId: null
      });
    }

  } catch (error) {
    console.error("❌ Error al generar PDF:", error.message);
  }
});

// ─────────────────────────────────────────────────────────────────────────────
// GET /pdf/:archivo
// ─────────────────────────────────────────────────────────────────────────────
app.get("/pdf/:archivo", (req, res) => {
  const filePath = path.join(OUTPUT_DIR, req.params.archivo);

  if (!fs.existsSync(filePath)) {
    return res.status(404).json({ error: "PDF no encontrado" });
  }

  res.setHeader("Content-Type", "application/pdf");
  res.setHeader("Content-Disposition", `attachment; filename="${req.params.archivo}"`);
  fs.createReadStream(filePath).pipe(res);
});

// ─────────────────────────────────────────────────────────────────────────────
app.listen(PORT, () => {
  console.log(`🚀 Servidor corriendo en http://localhost:${PORT}`);
  console.log(`📡 Webhook URL: ${MY_PUBLIC_URL}/webhook/nubarium`);
});